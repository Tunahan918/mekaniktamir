@inject bakimonarim.Data.AppDbContext dbContext;
@using bakimonarim.Data;
@{
    string adsoyad = "", yetki = "";
    if (User.Identity.IsAuthenticated)
    {

        foreach (var item in User.Claims)
        {
            if (item.Type == "adsoyad")
            {
                adsoyad = item.Value;
            }
            if (item.Type == System.Security.Claims.ClaimTypes.Role)
            {
                yetki = item.Value;
            }
        }
        @*@User.FindFirst(claim => claim.Type == System.Security.Claims.ClaimTypes.Role)?.Value*@
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/overlayScrollbars@1.13.1/css/OverlayScrollbars.min.css">

    @RenderSection("header", required: false)
</head>
<body class="hold-transition sidebar-mini layout-fixed">
    <div class="wrapper">
        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-dark navbar-primary">
            <!-- Left navbar links -->
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a href="/admin/home/index" class="nav-link">Giriş</a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a href="/admin/home/ayarlar" class="nav-link">Ayarlar</a>
                </li>
            </ul>
            <!-- Right navbar links -->
            <ul class="navbar-nav ml-auto">

                <li class="nav-item">
                    <a class="nav-link" data-widget="control-sidebar" data-slide="true" href="#" role="button">
                        <span class="hidden-xs">MekanikTamir</span>
                    </a>
                </li>
            </ul>
        </nav>
        <!-- /.navbar -->
        <!-- Main Sidebar Container -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <!-- Brand Logo -->
            <a href="index3.html" class="brand-link">
                <img src="/img/logos/12115.jpg" alt="Logo" class="brand-image img-circle elevation-3" style="opacity: .8; width:33px; height:33px; object-fit:cover;">
                <span class="brand-text font-weight-light">Yönetim PANELİ</span>
            </a>
            <!-- Sidebar -->
            <div class="sidebar">
                <!-- Sidebar user panel (optional) -->
                <div class="user-panel mt-3 pb-3 mb-3 d-flex">
                    <div class="image">
                        <img src="/img/logos/12115.jpg" class="img-circle elevation-2" alt="User Image" style="width:34px; height:34px; object-fit:cover;">
                    </div>
                    <div class="info">
                        <a href="#" class="d-block">@adsoyad <small>@(yetki == "admin" ? "[Admin]" : "[User]")</small></a>
                    </div>
                </div>
                <!-- SidebarSearch Form -->
                <div class="form-inline">
                    <div class="input-group" data-widget="sidebar-search">
                        <input class="form-control form-control-sidebar" type="search" placeholder="" aria-label="Search">
                        <div class="input-group-append">
                            <button class="btn btn-sidebar">
                                <i class="fas fa-search fa-fw"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <!-- Sidebar Menu -->
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
                        <!-- Add icons to the links using the .nav-icon class
    with font-awesome or any other icon font library -->
                        <li class="nav-item">
                            <a href="/admin/home/index" data-level="0" class="nav-link">
                                <i class="nav-icon fas fa-home"></i>
                                <p>Giriş</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/admin/urun" data-level="0" class="nav-link">
                                <i class="nav-icon fas fa-tasks"></i>
                                <p>Ürünler</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/admin/kategori" data-level="0" class="nav-link">
                                <i class="fas fa-cogs nav-icon"></i>
                                <p>Ürün Kategoriler</p>
                            </a>
                        </li>
                     
                        <li class="nav-item">
                            <a href="/admin/yoneticiler" data-level="0" class="nav-link">
                                <i class="fas fa-users-cog nav-icon"></i>
                                <p>Yöneticiler</p>
                            </a>
                        </li>
                    
                        <li class="nav-item">
                            <a href="/admin/home/Cikis" class="nav-link">
                                <i class="nav-icon fas fa-sign-out-alt"></i>
                                <p>Çıkış</p>
                            </a>
                        </li>

                    </ul>
                </nav>
                <!-- /.sidebar-menu -->
            </div>
            <!-- /.sidebar -->
        </aside>
        <!-- Content Wrapper. Contains page content -->

        @RenderBody()

        <!-- /.content-wrapper -->
        <footer class="main-footer">
            <strong>&copy; @DateTime.Now.Year MekanikTamir <a href="https://www.mekaniktamir.com">www.mekaniktamir.com</a>.</strong> <span>Tüm Hakları Saklıdır.</span>
            <div class="float-right d-none d-sm-inline-block">
                <b>MekanikTamir</b>
            </div>
        </footer>

    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.0/jquery-ui.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
    @RenderSection("footer", false);
    <script>
        var path = location.pathname;
        var level = $("ul.nav-sidebar li a[href='" + path + "']").attr("data-level");
        if (level > 0) {
            // Tam eşleşme kontrolü yapıyoruz
            $("ul.nav-sidebar li ul.nav-treeview li a").filter(function () {
                return $(this).attr("href") === path;
            }).parent().parent().parent().addClass("menu-open")
                .find("a").filter(function () {
                    return $(this).attr("href") === path;
                }).addClass("active");
        } else {
            $("ul.nav-sidebar li a[href='" + path + "']").parent().addClass("menu-open");
            $("ul.nav-sidebar li a[href='" + path + "']").addClass("active");
        }
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
