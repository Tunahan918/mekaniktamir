@model IEnumerable<bakimonarim.Data.Kategori>

@{
    ViewBag.Title = "Kategori Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutPageAdmin.cshtml";
}

<div class="content-wrapper">
    <section class="content-header">
        <h1><small>Kategori</small> Listesi</h1>
        <ol class="breadcrumb">
            <li>Kategori Listesi</li>
        </ol>
    </section>

    <section class="content">
        <div class="box">
            <div class="box-header with-border">
                <a href="@Url.Action("Create")" class="btn btn-primary btn-sm">
                    <i class="fa fa-plus"></i> Yeni Kategori
                </a>
            </div>
            <div class="box-body">
                @if (TempData["Mesaj"] != null)
                {
                    <div class="alert alert-success">@TempData["Mesaj"]</div>
                }
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Kategori Adı</th>
                            <th>SEO</th>
                            <th>Sıra</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.KategorId</td>
                                <td>@item.Ad</td>
                                <td>@item.Seo</td>
                                <td>@item.Sira</td>
                                <td>
                                    <a href="@Url.Action("Edit", new { id = item.KategorId })" class="btn btn-warning btn-xs">
                                        <i class="fa fa-edit"></i> Düzenle
                                    </a>
                                    <a href="@Url.Action("Delete", new { id = item.KategorId })" class="btn btn-danger btn-xs">
                                        <i class="fa fa-trash"></i> Sil
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>
