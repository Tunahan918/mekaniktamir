@model bakimonarim.Data.Kategori

@{
    ViewBag.Title = "Kategori Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutPageAdmin.cshtml";
}

<div class="content-wrapper">
    <section class="content-header">
        <h1><small>Kategori</small> Düzenle</h1>
        <ol class="breadcrumb">
            <li><a href="@Url.Action("Index")">Kategori Listesi</a></li>
            <li>Düzenle</li>
        </ol>
    </section>

    <section class="content">
        <div class="box box-warning">
            <div class="box-header with-border">
                <h3 class="box-title">Kategori Bilgileri</h3>
            </div>
            <div class="box-body">
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.KategorId)
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="form-group">
                        @Html.LabelFor(m => m.Ad, "Kategori Adı", new { @class = "control-label" })
                        @Html.EditorFor(m => m.Ad, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(m => m.Ad, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.Seo, "SEO (URL)", new { @class = "control-label" })
                        @Html.EditorFor(m => m.Seo, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(m => m.Seo, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(m => m.Sira, "Sıra", new { @class = "control-label" })
                        @Html.EditorFor(m => m.Sira, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(m => m.Sira, "", new { @class = "text-danger" })
                    </div>

                    <button type="submit" class="btn btn-warning">
                        <i class="fa fa-save"></i> Güncelle
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-default">
                        <i class="fa fa-arrow-left"></i> Geri Dön
                    </a>
                }
            </div>
        </div>
    </section>
</div>
