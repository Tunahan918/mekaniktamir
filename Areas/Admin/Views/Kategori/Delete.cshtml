@model bakimonarim.Data.Kategori

@{
    ViewBag.Title = "Kategori Sil";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutPageAdmin.cshtml";
}

<div class="content-wrapper">
    <section class="content-header">
        <h1><small>Kategori</small> Sil</h1>
        <ol class="breadcrumb">
            <li><a href="@Url.Action("Index")">Kategori Listesi</a></li>
            <li>Sil</li>
        </ol>
    </section>

    <section class="content">
        <div class="box box-danger">
            <div class="box-header with-border">
                <h3 class="box-title">Silmek istediğinize emin misiniz?</h3>
            </div>
            <div class="box-body">
                <table class="table table-bordered">
                    <tr>
                        <th>Kategori Adı</th>
                        <td>@Model.Ad</td>
                    </tr>
                    <tr>
                        <th>SEO</th>
                        <td>@Model.Seo</td>
                    </tr>
                    <tr>
                        <th>Sıra</th>
                        <td>@Model.Sira</td>
                    </tr>
                </table>

                <div class="alert alert-danger">
                    <i class="fa fa-warning"></i> Bu kategoriyi silmek, içindeki ürünleri de etkileyebilir!
                </div>

                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="fa fa-trash"></i> Evet, Sil
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-default">
                        <i class="fa fa-times"></i> Vazgeç
                    </a>
                }
            </div>
        </div>
    </section>
</div>
