@model IEnumerable<bakimonarim.Data.Urun>

@{
    ViewBag.Title = "Ürün Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutPageAdmin.cshtml";
}

<div class="content-wrapper">
    <section class="content-header">
        <h1><small>Ürün</small> Listesi</h1>
        <ol class="breadcrumb">
            <li>Ürün Listesi</li>
        </ol>
    </section>

    <section class="content">
        <div class="box">
            <div class="box-header with-border">
                <a href="@Url.Action("Create")" class="btn btn-primary btn-sm">
                    <i class="fa fa-plus"></i> Yeni Ürün
                </a>
            </div>
            <div class="box-body">
                @if (TempData["Mesaj"] != null)
                {
                    <div class="alert alert-success">@TempData["Mesaj"]</div>
                }
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Resim</th>
                            <th>Ürün Adı</th>
                            <th>Kategori</th>
                            <th>Tarih</th>
                            <th>Onay</th>
                            <th>Sıra</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.UrunId</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.vitrinresim))
                                    {
                                        <img src="@item.vitrinresim" style="width:60px; height:60px; object-fit:cover; border-radius:4px;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">Resim yok</span>
                                    }
                                </td>
                                <td>@item.Adi</td>
                                <td>@item.Kategori?.Ad</td>
                                <td>@item.Tarih.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @if (item.Onay)
                                    {
                                        <span class="badge badge-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Pasif</span>
                                    }
                                </td>
                                <td>@item.Sira</td>
                                <td>
                                    <a href="@Url.Action("Edit", new { id = item.UrunId })" class="btn btn-warning btn-xs">
                                        <i class="fa fa-edit"></i> Düzenle
                                    </a>
                                    <a href="@Url.Action("Delete", new { id = item.UrunId })" class="btn btn-danger btn-xs">
                                        <i class="fa fa-trash"></i> Sil
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>
