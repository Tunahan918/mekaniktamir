@model List<bakimonarim.Data.Urun>
@{
    ViewData["Title"] = "Ürünler";
}

			<div role="main" class="main">

				<section class="page-header page-header-modern bg-color-grey page-header-lg">
					<div class="container">
						<div class="row">
							<div class="col-md-8 order-2 order-md-1 align-self-center p-static">
<h1 class="text-color-dark font-weight-bold">Ürünler</h1>
							</div>
							<div class="col-md-4 order-1 order-md-2 align-self-center">
								<ul class="breadcrumb d-flex justify-content-md-end text-3-5">
									<li><a href="/" class="text-color-default text-color-hover-primary text-decoration-none">HOME</a></li>
<li class="active">Ürünler</li>
								</ul>
							</div>
						</div>
					</div>
				</section>

				<div class="shop container py-4 my-5">
					<div class="row align-items-center justify-content-between mb-4">
						<div class="col-auto mb-3 mb-md-0 order-md-2">
							<span>@(Model?.Count ?? 0) ürün listeleniyor</span>
						</div>
						<div class="col-md-8 order-md-1">
							<form method="get" class="d-flex gap-2 flex-wrap">
								@if (ViewBag.Kategoriler != null)
								{
									<div class="custom-select-1" style="max-width: 220px;">
										<select name="kategoriId" class="form-select form-control border px-3 py-2 h-auto" onchange="this.form.submit()">
											<option value="">Tüm Kategoriler</option>
											@foreach (var kat in (List<bakimonarim.Data.Kategori>)ViewBag.Kategoriler)
											{
												<option value="@kat.KategorId" selected="@(ViewBag.SecilenKategori != null && (int)ViewBag.SecilenKategori == kat.KategorId ? "selected" : null)">
													@kat.Ad
												</option>
											}
										</select>
									</div>
								}
							</form>
						</div>
					</div>
					<div class="products row row-gutter-sm mb-4">
						@if (Model != null && Model.Any())
						{
							@foreach (var urun in Model)
							{
								<div class="col-sm-6 col-lg-3 mb-4">
									<div class="product mb-0">
										<div class="product-thumb-info mb-3">
											<div class="product-thumb-info-image bg-light" style="height:220px; overflow:hidden;">
												@if (!string.IsNullOrEmpty(urun.vitrinresim))
												{
													<img alt="@urun.Adi" class="img-fluid w-100 h-100" src="@urun.vitrinresim" style="object-fit:cover;">
												}
												else
												{
													<img alt="@urun.Adi" class="img-fluid" src="/img/demos/auto-services/products/product-1.jpg">
												}
											</div>
										</div>
										<div class="d-flex justify-content-between">
											<div>
												<a href="/Home/Urunler?kategoriId=@urun.KategoriId" class="d-block text-uppercase text-decoration-none text-color-default text-color-hover-primary line-height-1 text-0 mb-1">@urun.Kategori?.Ad</a>
												<h3 class="text-3-5 font-weight-medium font-alternative text-transform-none line-height-3 mb-0">
													<a class="text-color-dark text-color-hover-primary">@urun.Adi</a>
												</h3>
											</div>
										</div>
									</div>
								</div>
							}
						}
						else
						{
							<div class="col-12 text-center py-5">
								<i class="fas fa-box-open text-muted" style="font-size:3rem;"></i>
								<p class="text-muted mt-3">Henüz ürün eklenmemiş.</p>
							</div>
						}
