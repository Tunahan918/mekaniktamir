                            <div class="galeri-overlay">
                                <div class="galeri-overlay-text">
                                    <h4>Tutkuyla Bakım</h4>
                                    <p>Her araç bizim için özeldir, ona göre hizmet veririz.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mb-4">
                    <div class="galeri-card">
                        <div class="galeri-item">
                            <img src="/img/home/harleymoto2.webp" alt="Motosiklet 2" />
                            <div class="galeri-overlay">
