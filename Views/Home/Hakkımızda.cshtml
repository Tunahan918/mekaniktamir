                <div class="col-sm-4 col-lg-2 mb-4 mb-sm-0"><img src="/img/logos/logo-12.png" alt class="img-fluid" style="max-width:100px;"></div>
                <div class="col-sm-4 col-lg-2"><img src="/img/logos/logo-13.png" alt class="img-fluid" style="max-width:100px;"></div>
